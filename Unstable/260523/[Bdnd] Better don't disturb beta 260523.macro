 to manually do this help me)\nautoActivation\u003d[days]: \n-- [0]: {v\u003dautoActivation[days][0]}\n-- [1]: {v\u003dautoActivation[days][1]}\n-- [2]: {v\u003dautoActivation[days][2]}\n-- [3]: {v\u003dautoActivation[days][3]}\n-- [4]: {v\u003dautoActivation[days][4]}\n-- [5]: {v\u003dautoActivation[days][5]}\n-- [6]: {v\u003dautoActivation[days][6]}\n[enable]: {v\u003dautoActivation[enable]}\n[Hour]: {v\u003dautoActivation[Hour]}\n[Minute]: {v\u003dautoActivation[Minute]}\nautoDeactivation\u003d[days]: \n-- [0]: {v\u003dautoDeactivation[days][0]}\n-- [1]: {v\u003dautoDeactivation[days][1]}\n-- [2]: {v\u003dautoDeactivation[days][2]}\n-- [3]: {v\u003dautoDeactivation[days][3]}\n-- [4]: {v\u003dautoDeactivation[days][4]}\n-- [5]: {v\u003dautoDeactivation[days][5]}\n-- [6]: {v\u003dautoDeactivation[days][6]}\n[enabled]: {v\u003dautoDeactivation[enable]}\n[Hour]: {v\u003dautoDeactivation[Hour]}\n[Minute]: {v\u003dautoDeactivation[Minute]}","m_prepend":false,"overwrite":true,"useAllFilesAccess":true,"disableLogging":false,"m_SIGUID":-5682824223253728794,"m_classType":"WriteToFileAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"filename":"{v\u003dfile name}.txt","pathName":"/better_dont_disturb","pathUri":"content://com.android.externalstorage.documents/tree/primary%3AMacrodroid%2Ffelixgamer27%2Fbetter_dont_disturb","staticFilename":false,"staticPathUri":"content://com.android.externalstorage.documents/document/primary%3AArroz%2FMacrodroid%2Ftest.txt","useAllFilesAccess":false,"variableName":"doesTheFileEvenExist","disableLogging":false,"m_SIGUID":-4935510295076534005,"m_classType":"ReadFileAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_option":6,"m_text":"{lv\u003ddoesTheFileEvenExist}","m_textManipulation":{"type":"SplitManipulation","params":["\\n","0"]},"variableName":"temp","disableLogging":false,"m_SIGUID":-7903903562180987246,"m_classType":"TextManipulationAction","m_comme