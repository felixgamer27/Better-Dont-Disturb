3dVerdadero\n\n[auto] (i had to manually do this help me)\nautoActivation\u003d[days]: \n-- [0]: Verdadero\n-- [1]: Verdadero\n-- [2]: Verdadero\n-- [3]: Verdadero\n-- [4]: Falso\n-- [5]: Falso\n-- [6]: Verdadero\n[enable]: Verdadero\n[Hour]: 22\n[Minute]: 0\nautoDeactivation\u003d[days]: \n-- [0]: Verdadero\n-- [1]: Verdadero\n-- [2]: Verdadero\n-- [3]: Verdadero\n-- [4]: Verdadero\n-- [5]: Falso\n-- [6]: Falso\n[enabled]: Verdadero\n[Hour]: 17\n[Minute]: 0","m_type":2,"supportsInput":false,"supportsOutput":true},{"dictionary":{"entries":[{"key":"Hour","variable":{"intValue":22,"variableType":1,"type":"IntegerValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"Minute","variable":{"intValue":0,"variableType":1,"type":"IntegerValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"enable","variable":{"booleanValue":true,"variableType":0,"type":"BooleanValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"days","variable":{"entries":[{"key":"0","variable":{"booleanValue":true,"variableType":0,"type":"BooleanValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"1","variable":{"booleanValue":true,"variableType":0,"type":"BooleanValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"2","variable":{"booleanValue":true,"variableType":0,"type":"BooleanValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"3","variable":{"booleanValue":true,"variableType":0,"type":"BooleanValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"4","variable":{"booleanValue":true,"variableType":0,"type":"BooleanValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"5","variable":{"booleanValue":false,"variableType":0,"type":"BooleanValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"6","variable":{"booleanValue":false,"variableType":0,"type":"BooleanValue"},"variableType":11,"type":"DictionaryEntry"}],"isArray":false,"variableType":4,"type":"Dictionary"},"variableType":11,"type":"DictionaryEntry"}],"isArray":false,"variableType":4,"type":"Dict