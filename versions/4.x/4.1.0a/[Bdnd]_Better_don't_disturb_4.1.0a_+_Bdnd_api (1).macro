-- [1]: Verdadero\n-- [2]: Verdadero\n-- [3]: Verdadero\n-- [4]: Verdadero\n-- [5]: Falso\n-- [6]: Falso\n[enable]: Falso\n[Hour]: 45\n[Minute]: 0\nautoDeactivation\u003d[days]: \n-- [0]: Verdadero\n-- [1]: Verdadero\n-- [2]: Verdadero\n-- [3]: Verdadero\n-- [4]: Verdadero\n-- [5]: Falso\n-- [6]: {v\u003dautoDeactivation[days][6]}\n[enabled]: Verdadero\n[Hour]: 0\n[Minute]: 0","m_type":2,"supportsInput":false,"supportsOutput":true},{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":14.0,"m_intValue":14,"m_name":"bdnd.NextFileNum","m_stringValue":"","m_type":1,"supportsInput":false,"supportsOutput":true},{"dictionary":{"entries":[{"key":"0","variable":{"textValue":"WARNING: this is a settings file, editing this file manually may corrupt the file, if you want to change the settings do it in the macro settings (more info in macro description)","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"1","variable":{"textValue":"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"2","variable":{"textValue":"ADVERTENCIA: este es un archivo de configuración, editar este archivo manualmente puede corromperlo, si quieres cambiar la configuración hazlo en las configuraciones de la macro (mas información en la descripción de la macro)","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"3","variable":{"textValue":"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"4","variable":{"textValue":"Better don\u0027t disturb, ver 4.0, Felixgamer27","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"5","variable":{"textValue":"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"6","variable":{"textValue":"[Macro info]"