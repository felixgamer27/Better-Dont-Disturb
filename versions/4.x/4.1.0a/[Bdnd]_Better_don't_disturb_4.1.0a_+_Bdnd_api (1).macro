Type":"ElseAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"cancelAfterTimeout":false,"m_message":"exporting the settings file will overwrite any existing file with the same name, continue?","m_title":"Settings file overwrite","negativeText":"Cancel","positiveText":"Continue","timeoutSeconds":30,"disableLogging":false,"m_SIGUID":-7230638021204834748,"m_classType":"ConfirmNextAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-9100393751307668772,"m_classType":"EndIfAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"allFilesPath":"/storage/emulated/0/macrodroid/felixgamer27/better_dont_disturb","m_append":false,"m_filename":"{v\u003dfile name}.txt","m_logText":"WARNING: this is a settings file, editing this file manually may corrupt the file, if you want to change the settings do it in the macro settings (more info in macro description)\n\nADVERTENCIA: este es un archivo de configuración, editar este archivo manualmente puede corromperlo, si quieres cambiar la configuración hazlo en las configuraciones de la macro (mas información en la descripción de la macro)\n\nBetter don\u0027t disturb, ver 4.0, Felixgamer27\n\n[Macro info]\nFile version\u003d2\nmacro version\u003d4.0\n\n[selected volume variables]\nselVolAlarms\u003d{v\u003dselVolAlarm}\nselVolBluetoothVoiceCall\u003d{v\u003dselVolBluetoothVoiceCalls}\nselVolMusic\u003d{v\u003dselVolMusic}\nselVolNotifications\u003d{v\u003dselVolNoti}\nselVolRingtone\u003d{v\u003dselVolRingtone}\nselVolSystem\u003d{v\u003dselVolSys}\nselVolVoiceCalls\u003d{v\u003dselVolVoiceCalls}\n\n[Modes]\nselectedDontDisturbMode\u003d{v\u003dselectedDontDisturbMode}\nselectedSoundMode\u003d{v\u003dselectedSoundMode}\n\n[block (change) variables]\nblockAlarms\u003d{v\u003dblockAlarms}\nblockBluetoothVoiceCall\u003d{v\u003dblockBluetoothVoiceCalls}\nblockMusic\u003d{v\u003dblockMusic}\nblockNotifications\u003d{v\u003dblockNotifications}\nblockRingtone\u003d{v\u003dblockRingtone}\nblockSystem\u003d{v\u003dblockSystem\n}\nblockVoiceCalls\u003d{v\u003dblockVoiceCalls}\n\n[auto] (i had to manually do this help me)\nautoActivation\u003d[days]: \n-- [0]: {v\u003dautoActivation[days][0]}\n-- [1]: {v\u003dautoActivation[days][1]}\n-- [2]: {v\u003dautoActivation[days][2]}\n-- [3]: {v\u003dautoActivation[days][3]}\n-- [4]: {v\u003dautoActivation[days][4]}\n-- [5]: {v\u003dautoActivation[days][5]}\n-- [6]: {v\u003dautoActivation[days][6]}\n[enable]: {v\u003dautoActivation[enable]}\n[Hour]: {v\u003dautoActivation[Hour]}\n[Minute]: {v\u003dautoActivation[Minute]}\nautoDeactivation\u003d[days]: \n-- [0]: {v\u003dautoDeactivation[days][0]}\n-- [1]: {v\u003dautoDeactivation[days][1]}\n-- [2]: {v\u003dautoDeactivation[days][2]}\n-- [3]: {v\u003dautoDeactivation[days][3]}\n-- [4]: {v\u003dautoDeactivation[days][4]}\n-- [5]: {v\u003dautoDeactivation[days][5]}\n-- [6]: {v\u003dautoDeactivation[days][6]}\n[enabled]: {v\u003dautoDeactivation[enable]}\n[Hour]: {v\u003dautoDeactivation[Hour]}\n[Minute]: {v\u003dautoDeactivation[Minute]}","m_prepend":false,"overwrite":true,"useAllFilesAccess":true,"disableLogging":false,"m_SIGUID":-5682824223253728794,"m_classType":"WriteToFileAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"filename":"{v\u003dfile name}.txt","pathName":"/better_dont_disturb","pathUri":"content://com.android.externalstorage.documents/tree/primary%3AMacrodroid%2Ffelixgamer27%2Fbetter_dont_disturb","staticFilename":false,"staticPathUri":"content://com.android.externalstorage.documents/document/primary%3AArroz%2FMacrodroid%2Ftest.txt","useAllFilesAccess":false,"variableName":"doesTheFileEvenExist","disableLogging":false,"m_SIGUID":-4935510295076534005,"m_classType":"ReadFileAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_option":6,"m_text":"{lv\u003ddoesTheFileEvenExist}","m_textManipulation":{"type":"SplitManipulation","params":["\\n","0"]}