tType":"TEXT","isBold":true,"isItalic":false,"isPassword":false,"padding":16,"populateWithValue":true,"showBackground":true,"showBorder":true,"singleLineOnly":true,"stringVariable":{"varName":"bugReportTxt"},"textColor":-1,"textSizeString":"16"},"guid":-6067706534027578520,"iconRes":2131231692,"lastRefreshValue":0}]},"sceneConfig":{"backgroundColor":-13421773,"backgroundImageDisplayMode":"CENTER_CROP","blockNextActions":true,"closeOnBackgroundTouch":false,"dismissOnBackPress":true,"dismissOnHomeTaskSwitch":false,"displayOption":{"type":"FullScreen","nameRes":2132021506},"foregroundColor":-1118482,"name":"bug report 4.1","roundedCornerAmount":0,"showOnLockScreen":false,"updateValuesOnSceneClose":false}},"disableLogging":false,"m_SIGUID":-7342835652771211326,"m_classType":"CustomSceneAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-6483003256517574033,"m_classType":"EndIfAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"allFilesPath":"/storage/emulated/0/macrodroid/felixgamer27/better_dont_disturb/bug_report","m_append":false,"m_filename":"{year}-{month_digit}-{dayofmonth}-{hour_0}-{minute}.txt","m_logText":"Better don\u0027t disturb, ver 4.1 bug report\nFelixgamer27\n\n[Bug report text]\n{lv\u003dbugReportTxt}\n\n[macrodroid info]\nmacrodroid version\u003d{macrodroid_version}\nversion code\u003d{macrodroid_version_code}\n\n[Macro info]\nbug report ver\u003d1.0\nmacro version\u003d4.0.1\n\n[Device info]\ndevice manufacturer\u003d{device_manufacturer}\ndevice model\u003d{device_model}\nandroid\u003d{android_version} (sdk{android_version_sdk})\n\n[block variables]\nblockAlarms\u003d{v\u003dblockAlarms}\nblockBluetoothVoiceCall\u003d{v\u003dblockBluetoothVoiceCalls}\nblockMusic\u003d{v\u003dblockMusic}\nblockNotifications\u003d{v\u003dblockNotifications}\nblockRingtone\u003d{v\u003dblockRingtone}\nblockSystem\u003d{v\u003dblockSystem\n}\nblockVoiceCalls\u003d{v\u003dblockVoiceCalls}\nselectedDontDisturbMode\u003d{v\u003dselectedDontDisturbMode}\n\n[auto]\nautoActivation\u003d{v\u003dautoActivation}\nautodeactivation\u003d{v\u003dautoDeactivation}","m_prepend":false,"overwrite":true,"useAllFilesAccess":true,"disableLogging":false,"m_SIGUID":-7223850893440193056,"m_classType":"WriteToFileAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_category":"[BDND] Better don\u0027t disturb","m_constraintList":[],"m_description":"","m_descriptionOpen":false,"m_enabled":false,"m_excludeLog":false,"m_headingColor":-11382190,"m_isOrCondition":false,"m_name":"Bug report 4.1","m_triggerList":[]},{"isInputExpanded":false,"isLocalExpanded":false,"isOutputExpanded":false,"isTestMode":false,"breakpoints":[],"disabledTimestamp":0,"exportedActionBlocks":[],"forceEvenIfNotEnabledTimestamp":0,"isActionBlock":true,"isExtra":false,"isFavourite":false,"lastEditedTimestamp":1774996415791,"localVariables":[],"localVarsAlphabetical":true,"m_GUID":-6199387651392811583,"m_actionList":[{"childrenCollapsed":false,"dontLogIfConditionIsFalse":false,"disableLogging":false,"m_SIGUID":-7537214007925875052,"m_classType":"IfConditionAction","m_constraintList":[{"checkCase":false,"dictionaryKeys":{"keys":[]},"dictionaryType":2,"enableRegex":false,"m_booleanValue":false,"m_doubleValue":0.0,"m_intCompareVariable":false,"m_intGreaterThan":false,"m_intLessThan":false,"m_intNotEqual":false,"m_intValue":0,"m_otherValueToCompare":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"{lv\u003dlast app}","m_stringValue":"","m_type":2,"supportsInput":true,"supportsOutput":true},"m_stringComparisonType":0,"m_stringEqual":true,"m_stringValue":"es","m_variable":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"selectedLanguage","m_stringValue":"","m_type":2,"supportsInput":true,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-8006537772979419786,"m_classType":"MacroDroidVariableConstraint","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_isDisabled":false,"m_isOrCondition":false},{"sceneDescription":{"itemList":{"items":[{"type":"SceneText","sceneTextConfig":{"autoSizeText":false,"enableAutoRefresh":false,"enableSelection":false,"htmlFormatting":false,"isBold":false,"isItalic":false,"maxLines":"3","maxLinesEnabled":false,"padding":"8","text":"Changelog","textAlignment":"Center","textColor":-1,"textSize":"50"},"guid":-7762684915794587739,"iconRes":2131232684,"lastRefreshValue":0},{"type":"SceneText","sceneTextConfig":{"autoSizeText":false,"enableAutoRefresh":false,"enableSelection":false,"htmlFormatting":false,"isBold":false,"isItalic":false,"maxLines":"3","maxLinesEnabled":false,"padding":"8","text":"Version 4.1.0a hotfix:\n• Arreglado error de idiomas en la sección de modos.\n\n\nversión 4.1 small update (30/3/26):\n• Arreglado error de splash.\n• Agregado hora para ejecutar update check y self-repair.\n• Mejorado auto-reparación.\n\n\nVersión 4.0.1 hotfix:\n• Arreglado error de idiomas\n• Arreglado error de ajustes secretos\n\nVersion 4.0: \"LA actualización\"\n\n[Nuevas funciones]\n• Añadida detección automática de idioma.\n• Añadido valor de volumen personalizado.\n• Añadido convertidor de archivos de configuración.\n• Setup traducido a español.\n• Añadida activación/desactivación automática a una hora seleccionada.\n• Añadido valor de volumen personalizado.\n• Añadidos comentarios dentro de la macro.\n• La macro funciona cuando el teléfono está bloqueado.\n• Añadida API (bloques de acción reutilizables) para macros externas.\n• Añadido menú secreto.\n\n[Estabilidad]\n• Añadido reinicio al cargar perfil/archivos de configuración.\n• Incluso si no tienes idioma, la macro funcionará en inglés.\n• Los archivos de configuración ahora son más estables.\n• Los archivos de configuración se cargan automáticamente para detectar errores fácilmente.\n• Añadidas opciones para asegurar compatibilidad con todos los dispositivos.\n\n[Corrección de bugs]\n• Se arregló el toast duplicado en inglés y la falta de mensaje en español.\n• Arreglados montones de bugs de la beta, incluyendo:\n   Bool\u003d55\n   Hour\u003dtrue\n   La macro es floja y no funciona los fines de semana\n   Cosas usando BluetoothVoiceCalls cuando no deberían\n\n\nVersión 3.0\n• Añadido setup.\n• Añadidos archivos de perfiles/configuración.\n• Traducida la mayoría de la macro a español.\n• Añadidos toast y vibración al activarse/desactivarse.\n\n\n2.0\n• Arreglado bug de “no molestar” activado siempre.\n• Añadidos modos de “no molestar”.\n• Añadidas opciones para bloquear manualmente todos los volúmenes.\n• Añadidos grupos de acciones para organizar mejor.\n• Añadido “long press” en QS Tile para abrir ajustes.\n\n\n1.1.1\n(esta versión nunca tuvo changelog oficial y no recuerdo exactamente qué cambió)\n• Arreglado un bug o algo así.\nAdaptada la macro para ser publicada.\n\n\n1.1\n(esta versión nunca se lanzó ni archivó y no recuerdo exactamente qué agregué)\n• Añadido blockAlarms.\n\n\n1.0\n(esta versión nunca se lanzó ni archivó y no recuerdo exactamente qué agregué)\n• Añadido saveVol.","textAlignment":"Start","textColor":-1,"textSize":"20"},"guid":-6361021706272199564,"iconRes":2131232684,"lastRefreshValue":0}]},"sceneConfig":{"backgroundColor":-13421773,"backgroundImageDisplayMode":"CENTER_CROP","blockNextActions":true,"closeOnBackgroundTouch":false,"dismissOnBackPress":true,"dismissOnHomeTaskSwitch":false,"displayOption":{"type":"FullScreen","nameRes":2132021506},"foregroundColor":-1118482,"name":"changelog es","roundedCornerAmount":0,"showOnLockScreen":false,"updateValuesOnSceneClose":false}},"disableLogging":false,"m_SIGUID":-8830563799881803471,"m_classType":"CustomSceneAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"dontLogIfConditionIsFalse":false,"disableLogging":false,"m_SIGUID":-8448534692320705112,"m_classType":"ElseIfConditionAction","m_constraintList":[{"checkCase":false,"dictionaryKeys":{"keys":[]},"dictionaryType":2,"enableRegex":false,"m_booleanValue":false,"m_doubleValue":0.0,"m_intCompareVariable":false,"m_intGreaterThan":false,"m_intLessThan":false,"m_intNotEqual":false,"m_intValue":0,"m_otherValueToCompare":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"{lv\u003dlast app}","m_stringValue":"","m_type":2,"supportsInput":true,"supportsOutput":true},"m_stringComparisonType":0,"m_stringEqual":true,"m_stringValue":"arg","m_variable":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"selectedLanguage","m_stringValue":"","m_type":2,"supportsInput":true,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-5780685283382738304,"m_classType":"MacroDroidVariableConstraint","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_isDisabled":false,"m_isOrCondition":false},{"sceneDescription":{"itemList":{"items":[{"type":"SceneText","sceneTextConfig":{"autoSizeText":false,"enableAutoRefresh":false,"enableSelection":false,"htmlFormatting":false,"isBold":false,"isItalic":false,"maxLines":"3","maxLinesEnabled":false,"padding":"8","text":"Changelog","textAlignment":"Center","textColor":-1,"textSize":"50"},"guid":-8206961491697469332,"iconRes":2131232684,"lastRefreshValue":0},{"type":"SceneText","sceneTextConfig":{"autoSizeText":false,"enableAutoRefresh":false,"enableSelection":false,"htmlFormatting":false,"isBold":false,"isItalic":false,"maxLines":"3","maxLinesEnabled":false,"padding":"8","text":"Version 4.1.0a hotfix:\n• Arreglado error de idiomas en la sección de modos.\n\n\nversión 4.1 small update (30/3/26):\n• Arreglado error de splash.\n• Agregado hora para ejecutar update check y self-repair.\n• Mejorado self-repair.\n\n\nVersión 4.0.1 hotfix:\n• Arreglado error de idiomas\n• Arreglado error de ajustes secretos\n\n\nVersión 4.0: LA update\n\n[Nuevas funciones]\n• Detección automática de idioma.\nVolumen customizado.\n• Convertidor de archivos de config.\n• Setup traducido al español.\n• Activación/desactivación automática a la hora que quieras.\n• Volumen customizado.\n• Comentarios dentro de la macro.\n• Funciona con el celu bloqueado.\n• API para macros externas (bloques reutilizables).\n• Menú secreto.\n\n[Estabilidad]\n• Reinicia al cargar perfil/config.\n• Si no tenés idioma, igual funciona en inglés.\n• Archivos de config más estables.\n• Se cargan automáticamente para encontrar errores fácil.\n• Opciones para compatibilidad con todos los dispositivos.\n\n[Corrección de bugs]\n• Toast duplicado en inglés / sin mensaje en español solucionado.\n• una banda de bugs de la beta arreglados, incluyendo:\n   Bool\u003d55\n   Hour\u003dtrue\n   La macro flojea los findes\n   Cosas usando BluetoothVoiceCalls cuando no corresponde\n\n\n3.0\n• Setup agregado.\n• Archivos de perfiles/config.\n• Mayor parte de la macro en español.\n• Toast + vibración al activar/desactivar.\n\n\n2.0\n• Bug de “no molestar” fijo.\n• Modos de “no molestar” agregados.\n• Bloqueo manual de todos los volúmenes.\n• Grupos de acciones para ordenar.\n• Long press en QS Tile para abrir ajustes.\n\n1.1.1\n(nunca tuvo changelog oficial y no me acuerdo bien qué cambió)\n• Bug arreglado o algo.\n• Macro adaptada para publicación.\n\n\n1.1\n(nunca se lanzó ni archivó y no me acuerdo bien qué agregué)\n• blockAlarms agregado.\n\n\n1.0\n(nunca se lanzó ni archivó y no me acuerdo bien qué agregué)\n• saveVol agregado.","textAlignment":"Start","textColor":-1,"textSize":"20"},"guid":-7099468394410171854,"iconRes":2131232684,"lastRefreshValue":0}]},"sceneConfig":{"backgroundColor":-13421773,"backgroundImageDisplayMode":"CENTER_CROP","blockNextActions":true,"closeOnBackgroundTouch":false,"dismissOnBackPress":true,"dismissOnHomeTaskSwitch":false,"displayOption":{"type":"FullScreen","nameRes":2132021506},"foregroundColor":-1118482,"name":"changelog arg","roundedCornerAmount":0,"showOnLockScreen":false,"updateValuesOnSceneClose":false}},"disableLogging":false,"m_SIGUID":-7725100327168937691,"m_classType":"CustomSceneAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"dontLogIfConditionIsFalse":false,"disableLogging":false,"m_SIGUID":-6964533105363340019,"m_classType":"ElseAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"sceneDescription":{"itemList":{"items":[{"type":"SceneText","sceneTextConfig":{"autoSizeText":false,"enableAutoRefresh":false,"enableSelection":false,"htmlFormatting":false,"isBold":false,"isItalic":false,"maxLines":"3","maxLinesEnabled":false,"padding":"8","text":"Changelog","textAlignment":"Center","textColor":-1,"textSize":"50"},"guid":-7686578456142551440,"iconRes":2131232684,"lastRefreshValue":0},{"type":"SceneText","sceneTextConfig":{"autoSizeText":false,"enableAutoRefresh":false,"enableSelection":false,"htmlFormatting":false,"isBold":false,"isItalic":false,"maxLines":"3","maxLinesEnabled":false,"padding":"8","text":"Version 4.1.0a hotfix:\n• Fixed language errors in modes section.\n\n\nversión 4.1 small update (30/3/26):\n• Fixed splash error.\n• Added time to run update check and self-repair.\n• Improved self-repair.\n\n\nVersión 4.0.1 hotfix:\n• Fixed language error\n• Fixed secret settings error\n\n\nUpdate 4.0, \"THE update\"\n\n[New features]\n• Added language auto detection.\n• Added custom volume value.\n• Added config files convertor.\n• Translated setup to Spanish.\n• Added auto activation/deactivation at a selected time.\n• Added custom volume value.\n• Added comments into macro.\n• Macro works when phone is locked.\n• Added API (reusable action blocks) for external macros.\n• Added secret menu.\n\n[Stability]\n• Added restart when load profile/config files.\n• Even if you don\u0027t have a language, the macro will still work in english.\n• Config files are now more stable.\n• Config files now auto load to detect errors easily.\n• Added options to ensure compatibility with al devices.\n\n[Bug correction]\n• Fixed duplicated toast message in English and no message in Spanish.\n• Fixed tons of bugs in beta, including:\nBool\u003d55\nHour\u003dtrue\nMacro is lazy and doesn\u0027t works on weekends\nThings using BluetoothVoiceCalls when they shouldn\u0027t\n\n\nUpdate 3.0:\n• Added setup.\n• Added profiles/settings files.\n• Translated most of the macro to Spanish.\n• Added toast message and vibration when activated/deactivated.\n\n\nUpdate 2.0:\n• Fixed don\u0027t disturb still being activated bug.\n• Added don\u0027t disturb modes.\n• Added options to manually block every volume.\n• Added action groups to help organize.\n• Added long press qs tile to open settings.\n\n\nUpdate 1.1.1:\n(this version never had a proper changelog and i don\u0027t remember exactly what changed)\n• fixed a bug or something.\n• adapted the macro for being published.\n\n\nUpdate 1.1:\n(this version was never released or archived and i don\u0027t remember exactly what changed)\n• Added blockAlarms.\n\n\nUpdate 1.0:\n(this version was never released or archived and i don\u0027t remember exactly what i added)\n• Added saveVol.","textAlignment":"Start","textColor":-1,"textSize":"20"},"guid":-9068895934439652582,"iconRes":2131232684,"lastRefreshValue":0}]},"sceneConfig":{"backgroundColor":-13421773,"backgroundImageDisplayMode":"CENTER_CROP","blockNextActions":true,"closeOnBackgroundTouch":false,"dismissOnBackPress":true,"dismissOnHomeTaskSwitch":false,"displayOption":{"type":"FullScreen","nameRes":2132021506},"for